# ─────────────────────────────────────────────
# .env  –  Secret Configuration File
# ─────────────────────────────────────────────
# NEVER share this file or push it to GitHub.
# Add ".env" to your .gitignore file!

# Your MongoDB connection string
# If using MongoDB Atlas (cloud), paste your connection string here.
# If using local MongoDB: mongodb://localhost:27017/auth_db
MONGO_URI=mongodb://localhost:27017/auth_db

# A long random string used to sign session cookies.
# Make this long and random — it's like your server's password.
SESSION_SECRET=replace_this_with_a_very_long_random_string_abc123xyz

# The port your backend runs on
PORT=5000